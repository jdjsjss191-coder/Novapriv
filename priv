        SuperJumpEnabled = not SuperJumpEnabled
    end
    
    -- Triggerbot Toggle
    if input.KeyCode == Enum.KeyCode[cfg['binds']['triggerbot']] then
        TriggerBotEnabled = not TriggerBotEnabled
    end
end)

