-- SILENT AIM HOOK
-- ============================================================================

local grm = getrawmetatable(game)
local oldindex = grm.__index
setreadonly(grm, false)

grm.__index = function(self, key)
    if not checkcaller() and self == Mouse and cfg['silent aimbot']['enabled'] then
        if key == "Hit" then
            if cfg['silent aimbot']['mode'] == 'Automatic' then
                SilentAimActive = true
            end
            
            if not SilentAimActive then return oldindex(self, key) end
            if not CurrentTarget then return oldindex(self, key) end
            if not CurrentTarget.Character then return oldindex(self, key) end
            
            if PlayerDead(CurrentTarget) then return oldindex(self, key) end
            if PlayerKnocked(CurrentTarget) then return oldindex(self, key) end
            
            local hrp = CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return oldindex(self, key) end
            
            -- Removed FOV check - can shoot behind you now
            -- Removed visibility check - can shoot through walls if target is locked
            
            -- Only check distance if enabled
            if not WithinDistance(hrp, cfg['silent aimbot']['distance']) then return oldindex(self, key) end
            
            local targetPart = nil
            if cfg['silent aimbot']['hitpart'] == 'Closest Part' then
                local mousePos = UserInputService:GetMouseLocation()
                targetPart = GetClosestBodyPart(CurrentTarget.Character, mousePos)
            elseif cfg['silent aimbot']['hitpart'] == 'Closest Point' then
                targetPart = hrp
            else
                targetPart = CurrentTarget.Character:FindFirstChild(cfg['silent aimbot']['hitpart'])
            end
            
            if not targetPart then
                targetPart = hrp
            end
            
            if targetPart then
                local predpos = PredictedPosition(targetPart, cfg['silent aimbot'])
                return CFrame_new(predpos)
            end
        end
    end
    return oldindex(self, key)
end

setreadonly(grm, true)

-- ============================================================================
-- CAMLOCK LOOP
-- ============================================================================

local function CamlockLoop()
    while true do
        task.wait()
        
        if not cfg['camlock']['enabled'] or not CamlockActive then
            CamlockTarget = nil
            continue
        end
        
        if SelfKnocked() then
            CamlockTarget = nil
            CamlockCachedTarget = nil
            CamlockActive = false
            continue
        end
        
        -- Validate cached target
        if CamlockCachedTarget then
            local isValid = true
            if not CamlockCachedTarget.Character then
                isValid = false
            elseif PlayerDead(CamlockCachedTarget) then
                isValid = false
            elseif PlayerKnocked(CamlockCachedTarget) then
                isValid = false
            elseif PlayerGrabbed(CamlockCachedTarget) then
                isValid = false
            end
            
            if isValid then
                CamlockTarget = CamlockCachedTarget
            else
                CamlockCachedTarget = nil
                CamlockTarget = nil
                CamlockActive = false
            end
        else
            -- Find new target
            local target = FindCamlockTarget()
            if target then
                CamlockTarget = target
                CamlockCachedTarget = target
            else
                CamlockTarget = nil
            end
        end
    end
end

-- ============================================================================
-- TARGET ACQUISITION LOOP
-- ============================================================================

local function SilentAimTargetLoop()
    while true do
        task.wait(ScanRate)
        
        if SelfKnocked() then
            CurrentTarget = nil
            CachedTarget = nil
            SilentAimActive = false
            FoundTarget = false
            continue
        end
        
        local shouldBeActive = false
        if cfg['silent aimbot']['mode'] == 'Automatic' then
            shouldBeActive = cfg['silent aimbot']['enabled']
        elseif cfg['silent aimbot']['mode'] == 'Select' then
            shouldBeActive = SilentAimActive and cfg['silent aimbot']['enabled']
        end
        
        if not shouldBeActive then
            -- Don't clear target in Select mode - let user manually unlock
            if cfg['silent aimbot']['mode'] == 'Automatic' then
                CurrentTarget = nil
                CachedTarget = nil
            end
            FoundTarget = false
            continue
        end
        
        -- In Select mode, only find target if we don't have one
        if cfg['silent aimbot']['mode'] == 'Select' then
            -- If we already have a locked target, validate it
            if CachedTarget then
                local isValid = true
                
                if not CachedTarget.Character then
                    isValid = false
                elseif PlayerDead(CachedTarget) then
                    isValid = false
                elseif PlayerKnocked(CachedTarget) then
                    isValid = false
                elseif PlayerGrabbed(CachedTarget) then
                    isValid = false
                end
                
                if isValid then
                    CurrentTarget = CachedTarget
                    FoundTarget = true
                else
                    -- Target died/invalid, clear it so user can select new one
                    CachedTarget = nil
                    CurrentTarget = nil
                    FoundTarget = false
                    SilentAimActive = false -- Auto-deactivate when target dies
                end
            else
                -- No cached target, find new one
                local target = nil
                
                if cfg['silent aimbot']['target method'] == 'Mouse' then
                    target = FindTargetClosestToMouse(
                        cfg['silent aimbot']['fov'],
                        cfg['silent aimbot']['distance'],
                        false
                    )
                else
                    target = FindTargetClosestToCamera(
                        cfg['silent aimbot']['fov'],
                        cfg['silent aimbot']['distance'],
                        false
                    )
                end
                
                if target then
                    CurrentTarget = target
                    CachedTarget = target
                    FoundTarget = true
                else
                    CurrentTarget = nil
                    FoundTarget = false
                end
            end
        else
            -- Automatic mode - always find closest target
            if cfg['silent aimbot']['sticky aim'] and CachedTarget then
                local isValid = true
                
                if not CachedTarget.Character then
                    isValid = false
                elseif PlayerDead(CachedTarget) then
                    isValid = false
                elseif PlayerKnocked(CachedTarget) then
                    isValid = false
                elseif PlayerGrabbed(CachedTarget) then
                    isValid = false
                end
                
                if isValid then
                    CurrentTarget = CachedTarget
                    FoundTarget = true
                else
                    CachedTarget = nil
                    CurrentTarget = nil
                    FoundTarget = false
                end
            end
            
            if not FoundTarget then
                local target = nil
                
                if cfg['silent aimbot']['target method'] == 'Mouse' then
                    target = FindTargetClosestToMouse(
                        cfg['silent aimbot']['fov'],
                        cfg['silent aimbot']['distance'],
                        false
                    )
                else
                    target = FindTargetClosestToCamera(
                        cfg['silent aimbot']['fov'],
                        cfg['silent aimbot']['distance'],
                        false
                    )
                end
                
                if target then
                    CurrentTarget = target
                    CachedTarget = target
                    FoundTarget = true
                else
                    CurrentTarget = nil
                    FoundTarget = false
                end
            end
        end
    end
end

-- ============================================================================
-- INPUT HANDLING
-- ============================================================================

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    local camlockKey = cfg['binds']['camlock']
    if input.KeyCode.Name == camlockKey then
        if cfg['camlock']['function'] == 'Toggle' then
            if CamlockActive then
                CamlockActive = false
                CamlockTarget = nil
                CamlockCachedTarget = nil
            else
                CamlockActive = true
            end
        elseif cfg['camlock']['function'] == 'Hold' then
            if not CamlockActive then
                CamlockActive = true
            end
        end
    end
    
    local silentKey = cfg['binds']['silent aim']
    if input.KeyCode.Name == silentKey then
        if cfg['silent aimbot']['mode'] == 'Select' then
            if cfg['silent aimbot']['function'] == 'Toggle' then
                -- Toggle mode: press once to lock, press again to unlock
                if SilentAimActive then
                    -- Unlock current target
                    SilentAimActive = false
                    CurrentTarget = nil
                    CachedTarget = nil
                    FoundTarget = false
                    TargetLine.Visible = false
                else
                    -- Lock onto new target
                    SilentAimActive = true
                end
            elseif cfg['silent aimbot']['function'] == 'Hold' then
                -- Hold mode: hold to lock, release to unlock
                if not SilentAimActive then
                    SilentAimActive = true
                end
            end
        end
    end
    
    local triggerKey = cfg['binds']['triggerbot']
    if input.KeyCode.Name == triggerKey then
        TriggerBotEnabled = not TriggerBotEnabled
    end
    
    local jumpKey = cfg['binds']['super jump']
    if input.KeyCode.Name == jumpKey then
        SuperJumpEnabled = not SuperJumpEnabled
    end
    
    local espKey = cfg['binds']['esp']
    if input.KeyCode.Name == espKey then
        cfg['esp']['enabled'] = not cfg['esp']['enabled']
        if cfg['esp']['enabled'] then
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    if not ESPLabels[player.UserId] then
                        AddESP(player)
                    end
                end
            end
        end
    end
    
    local speedKey = cfg['binds']['speed']
    if input.KeyCode.Name == speedKey then
        SpeedEnabled = not SpeedEnabled
    end
end)

UserInputService.InputEnded:Connect(function(input, processed)
    if processed then return end
    
    local camlockKey = cfg['binds']['camlock']
    if input.KeyCode.Name == camlockKey then
        if cfg['camlock']['function'] == 'Hold' then
            CamlockActive = false
            CamlockTarget = nil
            CamlockCachedTarget = nil
        end
    end
    
    local silentKey = cfg['binds']['silent aim']
    if input.KeyCode.Name == silentKey then
        if cfg['silent aimbot']['mode'] == 'Select' then
            if cfg['silent aimbot']['function'] == 'Hold' then
                -- Release to unlock
                SilentAimActive = false
                CurrentTarget = nil
                CachedTarget = nil
                FoundTarget = false
                TargetLine.Visible = false
            end
        end
    end
end)

