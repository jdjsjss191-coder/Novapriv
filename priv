local function TriggerBot()
    if not cfg['triggerbot']['enabled'] then return end
    if not TriggerBotEnabled then return end
    if HoldingKnife() then return end
    if tick() - LastTriggerClick < cfg['triggerbot']['delay'] then return end
    
    if CurrentTarget and CurrentTarget.Character then
        local char = CurrentTarget.Character
        
        if PlayerKnocked(CurrentTarget) then return end
        if PlayerDead(CurrentTarget) then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        if not CanSee(hrp) then return end
        if not WithinDistance(hrp, cfg['triggerbot']['distance']) then return end
        if cfg['triggerbot']['fov']['enabled'] and not MouseInFOVConfig(cfg['triggerbot']['fov'], hrp) then return end
    end
    
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    tool:Activate()
    LastTriggerClick = tick()
end

