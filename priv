local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local EnumMaterial = Enum.Material.Neon

-- Initialize hitbox state
local HITBOX_SIZE = Vector3.new(cfg['hitbox expander']['size'], cfg['hitbox expander']['size'], cfg['hitbox expander']['size'])
local HitboxTransparency = cfg['hitbox expander']['transparency']
local HitboxEnabled = cfg['hitbox expander']['enabled']

-- Object pooling for outlines
local outlinePool = {}

-- Function to get or create outline
local function getOutline(part)
    local outline = part:FindFirstChild("Outline")
    if not outline then
        outline = #outlinePool > 0 and table.remove(outlinePool) or Instance.new("SelectionBox")
        outline.LineThickness = 0.05
        outline.Color3 = Color3.fromRGB(108, 59, 170)
        outline.Name = "Outline"
    end
    outline.Adornee = part
    outline.Parent = part
    outline.Transparency = 0
    return outline
end

-- Function to release outline
local function releaseOutline(outline)
    outline.Adornee = nil
    outline.Parent = nil
    table.insert(outlinePool, outline)
end

-- Throttle updates
local lastUpdate = tick()

-- Function to update hitboxes
local function updateHitboxes()
    if not HitboxEnabled then return end
    
    local now = tick()
    if now - lastUpdate < 0.2 then return end
    lastUpdate = now
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character then
                local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                if humanoidRootPart then
                    local bodyEffects = character:FindFirstChild("BodyEffects")
                    local isKOd = bodyEffects and bodyEffects:FindFirstChild("K.O") and bodyEffects["K.O"].Value
                    local isGrabbed = character:FindFirstChild("GRABBING_CONSTRAINT") ~= nil
                    
                    if isKOd or isGrabbed then
                        if humanoidRootPart.Size ~= Vector3.new(0, 0, 0) then
                            humanoidRootPart.Size = Vector3.new(0, 0, 0)
                            humanoidRootPart.Transparency = 1
                            local outline = humanoidRootPart:FindFirstChild("Outline")
                            if outline then releaseOutline(outline) end
                        end
                    else
                        if humanoidRootPart.Size ~= HITBOX_SIZE then
                            humanoidRootPart.Size = HITBOX_SIZE
                            humanoidRootPart.Transparency = HitboxTransparency
                            humanoidRootPart.BrickColor = BrickColor.new(Color3.fromRGB(0, 0, 0))
                            humanoidRootPart.Material = EnumMaterial
                            humanoidRootPart.CanCollide = false
                            getOutline(humanoidRootPart)
                        else
                            humanoidRootPart.Transparency = HitboxTransparency
                        end
                        
                        local outline = humanoidRootPart:FindFirstChild("Outline")
                        if outline then
                            outline.Color3 = Color3.fromRGB(108, 59, 170)
                            outline.Transparency = 0
                        end
                    end
                end
            end
        end
    end
end

-- Use Heartbeat for smooth updates
RunService.Heartbeat:Connect(function()
    if HitboxEnabled then
        updateHitboxes()
    else
        -- Reset hitboxes if disabled
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local character = player.Character
                if character then
                    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                    if humanoidRootPart then
                        humanoidRootPart.Size = Vector3.new(2, 2, 1)
                        humanoidRootPart.Transparency = 1
                        local outline = humanoidRootPart:FindFirstChild("Outline")
                        if outline then releaseOutline(outline) end
                    end
                end
            end
        end
    end
end)

