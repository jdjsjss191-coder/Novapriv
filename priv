        TargetLine.Visible = false
        return
    end
    
    local screenpos, onscreen = Camera:WorldToViewportPoint(hrp.Position)
    
    if onscreen and screenpos.Z > 0 then
        local mpos = UserInputService:GetMouseLocation()
        
        TargetLine.From = Vector2_new(mpos.X, mpos.Y)
        TargetLine.To = Vector2_new(screenpos.X, screenpos.Y)
        TargetLine.Color = cfg['target line']['color']
        TargetLine.Visible = true
    else
        TargetLine.Visible = false
    end
end

-- ============================================================================
-- TRIGGERBOT
-- ============================================================================

local function TriggerBot()
    if not cfg['triggerbot']['enabled'] then return end
    if not TriggerBotEnabled then return end
    if HoldingKnife() then return end
    if tick() - LastTriggerClick < cfg['triggerbot']['delay'] then return end
    
    if CurrentTarget and CurrentTarget.Character then
        local char = CurrentTarget.Character
        
        if PlayerKnocked(CurrentTarget) then return end
        if PlayerDead(CurrentTarget) then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        if not CanSee(hrp) then return end
        if not WithinDistance(hrp, cfg['triggerbot']['distance']) then return end
        if cfg['triggerbot']['fov']['enabled'] and not MouseInFOVConfig(cfg['triggerbot']['fov'], hrp) then return end
    end
    
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    tool:Activate()
    LastTriggerClick = tick()
end

-- ============================================================================
-- RAPID FIRE (Enhanced - Auto-equips any gun)
-- ============================================================================

local function StartRapidFire()
    if RapidFireActive then return end
    RapidFireActive = true
    
    local isMouseDown = false
    
    -- Mouse button tracking
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isMouseDown = true
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isMouseDown = false
        end
    end)
    
    -- Auto-equip function
    local function autoEquipTool()
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if not backpack then return nil end
        
        local bestTool = nil
        
        -- Prioritize tools named "Rifle" or "Aug"
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Ammo") then
                local toolName = tool.Name:lower()
                if toolName:find("rifle") or toolName:find("aug") then
                    bestTool = tool
                    break
                elseif not bestTool then
                    bestTool = tool -- Fallback if no prioritized tool is found
                end
            end
        end
        
        if bestTool then
            bestTool.Parent = LocalPlayer.Character -- Equip the tool
            -- Wait until the tool is fully equipped
            repeat task.wait() until LocalPlayer.Character:FindFirstChildOfClass("Tool") == bestTool
            return bestTool
        end
        
        return nil
    end
    
    -- Rapid fire loop
    task.spawn(function()
        while cfg['rapid fire']['enabled'] do
            if isMouseDown then
                local char = LocalPlayer.Character
                if char then
                    local tool = char:FindFirstChildOfClass("Tool")
                    
                    -- Auto-equip if no tool is equipped
                    if not tool then
                        tool = autoEquipTool()
                    end
                    
                    if tool then
                        tool:Activate()
                    end
                end
            end
            task.wait(0.01) -- 100 shots per second
        end
    end)
end

-- ============================================================================
-- ESP SYSTEM
-- ============================================================================

local function AddESP(player)
    if player == LocalPlayer then return end
    if not cfg['esp']['enabled'] then return end
    
    local esp = {
        player = player,
        nametag = Drawing.new("Text"),
    }
    
    -- Font mapping
    local fontMap = {
        ['Plex'] = Drawing.Fonts.Plex,
        ['Monospace'] = Drawing.Fonts.Monospace,
        ['UI'] = Drawing.Fonts.UI,
        ['System'] = Drawing.Fonts.System
    }
    
    esp.nametag.Size = 14
    esp.nametag.Center = true
    esp.nametag.Outline = true
    esp.nametag.OutlineColor = Color3.fromRGB(0, 0, 0)
    esp.nametag.Color = cfg['esp']['color']
    esp.nametag.Font = fontMap[cfg['esp']['font']] or Drawing.Fonts.Plex
    esp.nametag.Visible = false
    esp.nametag.ZIndex = 1000
    
    ESPLabels[player.UserId] = esp
end

local function RemoveESP(player)
    local esp = ESPLabels[player.UserId]
    if esp then
        esp.nametag:Remove()
        ESPLabels[player.UserId] = nil
    end
end

local function RefreshESP()
    if not cfg['esp']['enabled'] then
        for userid, esp in pairs(ESPLabels) do
            esp.nametag:Remove()
            ESPLabels[userid] = nil
        end
        return
    end
    
    for userid, esp in pairs(ESPLabels) do
        local player = esp.player
        if not player or not player.Parent then
            esp.nametag.Visible = false
            esp.nametag:Remove()
            ESPLabels[userid] = nil
            continue
        end
        
        if player.Character and player.Character.Parent and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Head") then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then
                esp.nametag.Visible = false
                continue
            end
            
            local head = player.Character.Head
            local hrp = player.Character.HumanoidRootPart
            
            local worldpos = head.Position + Vector3_new(0, 1.5, 0)
            local esppos, onscreen = Camera:WorldToViewportPoint(worldpos)
            
            if onscreen and esppos.Z > 0 then
                esp.nametag.Position = Vector2_new(esppos.X, esppos.Y)
                
                local text = player.Name
                if cfg['esp']['show distance'] then
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local dist = (char.HumanoidRootPart.Position - hrp.Position).Magnitude
                        text = text .. " [" .. math_floor(dist) .. "]"
                    end
                end
                
                if cfg['esp']['show health'] then
                    text = text .. " [" .. math_floor(hum.Health) .. "]"
                end
                
                esp.nametag.Text = text
                
                if CurrentTarget == player then
                    esp.nametag.Color = Color3.fromRGB(255, 0, 0)
                else
                    esp.nametag.Color = cfg['esp']['color']
                end
                
                esp.nametag.Visible = true
            else
                esp.nametag.Visible = false
            end
        else
            esp.nametag.Visible = false
        end
    end
end

