local function FindTargetClosestToMouse(fovcfg, distcfg, knifecheck)
    if knifecheck and HoldingKnife() then return nil end
    
    local mousePos = UserInputService:GetMouseLocation()
    local fovSizeSquared = fovcfg and fovcfg['enabled'] and (fovcfg['size'] * fovcfg['size']) or math_huge
    
    local closestPlayer = nil
    local closestVisible = nil
    local closestDistSquared = math_huge
    local closestVisibleDistSquared = math_huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        if not IsValidAddress(player.Character) then continue end
        
        local head = player.Character:FindFirstChild("Head")
        if not head then continue end
        
        if IsSameTeam(player) then continue end
        if PlayerDead(player) then continue end
        if PlayerKnocked(player) then continue end
        if PlayerGrabbed(player) then continue end
        
        local screenCoords, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen or screenCoords.Z <= 0 then continue end
        
        local screenPos2D = Vector2_new(screenCoords.X, screenCoords.Y)
        
        local dx = mousePos.X - screenPos2D.X
        local dy = mousePos.Y - screenPos2D.Y
        local distSquared = dx * dx + dy * dy
        
        if fovcfg and fovcfg['enabled'] and distSquared > fovSizeSquared then continue end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp and not WithinDistance(hrp, distcfg) then continue end
        
        local isVisible = CanSee(head)
        
        if isVisible then
            if distSquared < closestVisibleDistSquared then
                closestVisibleDistSquared = distSquared
                closestVisible = player
            end
        else
            if distSquared < closestDistSquared then
                closestDistSquared = distSquared
                closestPlayer = player
            end
        end
    end
    
    if closestVisible then return closestVisible end
    if cfg['settings']['wall fallback'] then return closestPlayer end
    return nil
end

local function FindTargetClosestToCamera(fovcfg, distcfg, knifecheck)
    if knifecheck and HoldingKnife() then return nil end
    
    local cameraPos = Camera.CFrame.Position
    local fovSizeSquared = fovcfg and fovcfg['enabled'] and (fovcfg['size'] * fovcfg['size']) or math_huge
    
    local closestPlayer = nil
    local closestDistSquared = math_huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        if not IsValidAddress(player.Character) then continue end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        
        if IsSameTeam(player) then continue end
        if PlayerDead(player) then continue end
        if PlayerKnocked(player) then continue end
        if PlayerGrabbed(player) then continue end
        if not WithinDistance(hrp, distcfg) then continue end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen or screenPos.Z <= 0 then continue end
        
        if fovcfg and fovcfg['enabled'] then
            local mousePos = UserInputService:GetMouseLocation()
            local dx = screenPos.X - mousePos.X
            local dy = screenPos.Y - mousePos.Y
            local screenDistSquared = dx * dx + dy * dy
            if screenDistSquared > fovSizeSquared then continue end
        end
        
        if not CanSee(hrp) then continue end
        
        local distSquared = FastDistanceSquared3D(cameraPos, hrp.Position)
        
        if distSquared < closestDistSquared then
            closestDistSquared = distSquared
            closestPlayer = player
        end
    end
    
    return closestPlayer
end

local function CalculateTargetPartPosition(target, config)
    if not target or not target.Character then return nil end
    
    local char = target.Character
    local mousePos = UserInputService:GetMouseLocation()
    local partpos = nil
    local selectedPart = nil
    
    if config['hitpart'] == 'Closest Part' then
        selectedPart = GetClosestBodyPart(char, mousePos)
        
        if not selectedPart then
            selectedPart = char:FindFirstChild("HumanoidRootPart")
        end
        
        if selectedPart then
            local predictedPos = PredictedPosition(selectedPart, config)
            local screenPos, onScreen = Camera:WorldToViewportPoint(predictedPos)
            
            if onScreen and screenPos.Z > 0 then
                partpos = Vector2_new(screenPos.X, screenPos.Y)
            end
        end
    
    elseif config['hitpart'] == 'Closest Point' then
        partpos = GetClosestPointOnTarget(char, mousePos)
        
        if not partpos then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local fallbackPos = PredictedPosition(hrp, config)
                local screenPos, onScreen = Camera:WorldToViewportPoint(fallbackPos)
                if onScreen and screenPos.Z > 0 then
                    partpos = Vector2_new(screenPos.X, screenPos.Y)
                end
            end
        end
    
    else
        selectedPart = char:FindFirstChild(config['hitpart'])
        
        if not selectedPart then
            selectedPart = char:FindFirstChild("HumanoidRootPart")
        end
        
        if selectedPart then
            local predictedPos = PredictedPosition(selectedPart, config)
            local screenPos, onScreen = Camera:WorldToViewportPoint(predictedPos)
            
            if onScreen and screenPos.Z > 0 then
                partpos = Vector2_new(screenPos.X, screenPos.Y)
            end
        end
    end
    
    if partpos then
        local screenSize = Camera.ViewportSize
        
        if partpos.X < 0 or partpos.X > screenSize.X or partpos.Y < 0 or partpos.Y > screenSize.Y then
            partpos = Vector2_new(
                math_clamp(partpos.X, 0, screenSize.X),
                math_clamp(partpos.Y, 0, screenSize.Y)
            )
        end
        
        if partpos.X ~= partpos.X or partpos.Y ~= partpos.Y or 
           partpos.X == math_huge or partpos.Y == math_huge or
           partpos.X == -math_huge or partpos.Y == -math_huge then
            partpos = Vector2_new(screenSize.X / 2, screenSize.Y / 2)
        end
    else
        local screenSize = Camera.ViewportSize
        partpos = Vector2_new(screenSize.X / 2, screenSize.Y / 2)
    end
    
    return partpos
end

