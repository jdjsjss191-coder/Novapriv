-- Nova Silent Aim Script
repeat task.wait() until shared.Nova
local Config = shared.Nova

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

-- Locals
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local Camera = Workspace.CurrentCamera

-- ============================================================================
-- BULLET DISTANCE MODIFIER - COMPREHENSIVE IMPLEMENTATION
-- ============================================================================

if Config['bullet distance'] and Config['bullet distance']['enabled'] then
    local bulletDistance = Config['bullet distance']['infinite'] and math.huge or Config['bullet distance']['custom distance']
    
    -- METHOD 1: Hook __namecall for remote calls
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if not checkcaller() then
            -- Hook bullet creation remotes
            if method == "FireServer" or method == "InvokeServer" then
                if typeof(self) == "Instance" and (
                    self.Name:lower():find("bullet") or 
                    self.Name:lower():find("damage") or
                    self.Name:lower():find("shoot") or
                    self.Name:lower():find("fire") or
                    self.Name:lower():find("gun")
                ) then
                    -- Modify any distance/range parameters
                    for i, arg in pairs(args) do
                        if typeof(arg) == "number" and arg > 10 and arg < 10000 then
                            args[i] = bulletDistance
                        end
                    end
                    return oldNamecall(self, unpack(args))
                end
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    -- METHOD 2: Hook __index for property reads
    local oldIndex
    oldIndex = hookmetamethod(game, "__index", function(self, key)
        if not checkcaller() then
            if typeof(self) == "Instance" then
                -- Hook MaxDistance, Range, Distance properties
                if key == "MaxDistance" or key == "Range" or key == "Distance" or key == "MaxRange" then
                    return bulletDistance
                end
                
                -- Hook bullet-related objects
                if self.Name:lower():find("bullet") or self.ClassName == "Attachment" then
                    if key == "MaxDistance" or key == "Range" then
                        return bulletDistance
                    end
                end
            end
        end
        
        return oldIndex(self, key)
    end)
    
    -- METHOD 3: Hook __newindex for property writes
    local oldNewIndex
    oldNewIndex = hookmetamethod(game, "__newindex", function(self, key, value)
        if not checkcaller() then
            if typeof(self) == "Instance" then
                -- Prevent setting low distance values
                if (key == "MaxDistance" or key == "Range" or key == "Distance") and typeof(value) == "number" then
                    return oldNewIndex(self, key, bulletDistance)
                end
            end
        end
        
        return oldNewIndex(self, key, value)
    end)
    
    -- METHOD 4: Monitor workspace for bullet objects
    local function ModifyBulletObject(obj)
        if obj:IsA("BasePart") and (
            obj.Name:lower():find("bullet") or 
            obj.Name:lower():find("projectile") or
            obj.Name:lower():find("shot")
        ) then
            -- Extend bullet lifetime
            task.spawn(function()
                while obj and obj.Parent do
                    -- Maintain velocity to prevent slowdown
                    if obj.AssemblyLinearVelocity.Magnitude < 1000 then
                        local currentVel = obj.AssemblyLinearVelocity
                        if currentVel.Magnitude > 0 then
                            obj.AssemblyLinearVelocity = currentVel.Unit * 2000
                        end
                    end
                    
                    -- Prevent despawn
                    if obj:FindFirstChild("Lifetime") then
                        obj.Lifetime.Value = bulletDistance
                    end
                    
                    task.wait(0.1)
                end
            end)
        end
        
        -- Hook attachments that might control bullet behavior
        if obj:IsA("Attachment") then
            for _, child in pairs(obj:GetChildren()) do
                if child:IsA("ParticleEmitter") or child:IsA("Beam") then
                    pcall(function()
                        if child.Lifetime then
                            child.Lifetime = NumberRange.new(bulletDistance, bulletDistance)
                        end
                    end)
                end
            end
        end
    end
    
    -- Monitor all workspace descendants
    for _, obj in pairs(Workspace:GetDescendants()) do
        ModifyBulletObject(obj)
    end
    
    Workspace.DescendantAdded:Connect(ModifyBulletObject)
    
    -- METHOD 5: Hook Debris service to prevent bullet cleanup
    local Debris = game:GetService("Debris")
    local oldAddItem = Debris.AddItem
    Debris.AddItem = function(item, lifetime)
        if typeof(item) == "Instance" and (
            item.Name:lower():find("bullet") or 
            item.Name:lower():find("projectile") or
            item.Name:lower():find("shot")
        ) then
            -- Extend lifetime dramatically
            return oldAddItem(item, bulletDistance)
        end
        return oldAddItem(item, lifetime)
    end
    
    -- METHOD 6: Hook gun tools to modify their range values
    local function HookGunTool(tool)
        if tool:IsA("Tool") then
            task.spawn(function()
                -- Wait for tool to fully load
                task.wait(0.5)
                
                -- Modify any range/distance values in the tool
                for _, obj in pairs(tool:GetDescendants()) do
                    if obj:IsA("NumberValue") or obj:IsA("IntValue") then
                        if obj.Name:lower():find("range") or 
                           obj.Name:lower():find("distance") or
                           obj.Name:lower():find("maxdist") then
                            obj.Value = bulletDistance
                            
                            -- Keep it modified
                            obj:GetPropertyChangedSignal("Value"):Connect(function()
                                if obj.Value ~= bulletDistance then
                                    obj.Value = bulletDistance
                                end
                            end)
                        end
                    end
                end
                
                -- Hook tool scripts if accessible
                for _, script in pairs(tool:GetDescendants()) do
                    if script:IsA("LocalScript") or script:IsA("ModuleScript") then
                        pcall(function()
                            local env = getsenv(script)
                            if env then
                                -- Override common range variables
                                if env.MaxRange then env.MaxRange = bulletDistance end
                                if env.Range then env.Range = bulletDistance end
                                if env.BulletDistance then env.BulletDistance = bulletDistance end
                                if env.MaxDistance then env.MaxDistance = bulletDistance end
                            end
                        end)
                    end
                end
            end)
        end
    end
    
    -- Monitor character for gun tools
    if LocalPlayer.Character then
        for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
            HookGunTool(tool)
        end
        
        LocalPlayer.Character.ChildAdded:Connect(HookGunTool)
    end
    
    LocalPlayer.CharacterAdded:Connect(function(char)
        char.ChildAdded:Connect(HookGunTool)
    end)
    
    -- Monitor backpack for gun tools
    if LocalPlayer.Backpack then
        for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
            HookGunTool(tool)
        end
        
        LocalPlayer.Backpack.ChildAdded:Connect(HookGunTool)
    end
    
    print("[Nova] Bullet Distance Modifier: " .. (Config['bullet distance']['infinite'] and "INFINITE" or tostring(bulletDistance)))
end

print("[Nova] Script loaded successfully!")
