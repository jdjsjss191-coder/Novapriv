-- MAIN RENDER LOOP
-- ============================================================================

RunService.RenderStepped:Connect(function(dt)
    -- Camlock camera manipulation
    if CamlockActive and CamlockTarget and cfg['camlock']['enabled'] then
        local char = CamlockTarget.Character
        if char then
            local targetPart = char:FindFirstChild(cfg['camlock']['hitpart'])
            if not targetPart then
                targetPart = char:FindFirstChild("HumanoidRootPart")
            end
            
            if targetPart then
                local predictedPos = PredictedPosition(targetPart, cfg['camlock'])
                local currentCFrame = Camera.CFrame
                local targetCFrame = CFrame.new(Camera.CFrame.Position, predictedPos)
                
                -- Apply smoothness
                local smoothness = cfg['camlock']['smoothness']
                Camera.CFrame = currentCFrame:Lerp(targetCFrame, smoothness)
            end
        end
    end
    
    TriggerBot()
    
    if SuperJumpEnabled and cfg['movement']['super jump']['enabled'] then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum.JumpPower = cfg['movement']['super jump']['power']
            end
        end
    end
    
    if SpeedEnabled and cfg['movement']['speed']['enabled'] then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum.WalkSpeed = cfg['movement']['speed']['value']
            end
        end
    end
    
    -- FOV boxes disabled
    UpdateTargetLine()
    RefreshESP()
end)

