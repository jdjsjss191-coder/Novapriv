-- Utility Functions
local function HoldingKnife()
    if not cfg['settings']['knife check'] then return false end
    local char = LocalPlayer.Character
    if not char then return false end
    local tool = char:FindFirstChildOfClass("Tool")
    return tool and tool.Name == "[Knife]"
end

local function PlayerKnocked(player)
    if not cfg['settings']['knock check'] then return false end
    if player.Character then
        local bodyeffects = player.Character:FindFirstChild("BodyEffects")
        if bodyeffects then
            local ko = bodyeffects:FindFirstChild("K.O")
            if ko and ko.Value == true then return true end
        end
    end
    return false
end

local function SelfKnocked()
    if not cfg['settings']['self knock check'] then return false end
    if LocalPlayer.Character then
        local bodyeffects = LocalPlayer.Character:FindFirstChild("BodyEffects")
        if bodyeffects then
            local ko = bodyeffects:FindFirstChild("K.O")
            if ko and ko.Value == true then return true end
        end
    end
    return false
end

local function CanSee(part)
    if not cfg['settings']['visible check'] then return true end
    if not part or not part.Parent then return false end
    
    local char = part.Parent
    local origin = Camera.CFrame.Position
    local dir = (part.Position - origin).Unit * (part.Position - origin).Magnitude
    
    local RayParams = RaycastParams.new()
    RayParams.FilterType = Enum.RaycastFilterType.Exclude
    RayParams.IgnoreWater = true
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character, char}
    
    local result = Workspace:Raycast(origin, dir, RayParams)
    return result == nil or result.Instance:IsDescendantOf(char)
end

local function WithinDistance(part, distcfg)
    if not distcfg or not distcfg['enabled'] then return true end
    if not part or not part.Parent then return false end
    
    local char = LocalPlayer.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    return (hrp.Position - part.Position).Magnitude <= distcfg['max distance']
end

local function GetBodyParts(char)
    return {
        char:FindFirstChild("Head"),
        char:FindFirstChild("UpperTorso"),
        char:FindFirstChild("HumanoidRootPart"),
        char:FindFirstChild("LowerTorso"),
        char:FindFirstChild("LeftUpperArm"),
        char:FindFirstChild("RightUpperArm"),
        char:FindFirstChild("LeftLowerArm"),
        char:FindFirstChild("RightLowerArm"),
        char:FindFirstChild("LeftHand"),
        char:FindFirstChild("RightHand"),
        char:FindFirstChild("LeftUpperLeg"),
        char:FindFirstChild("RightUpperLeg"),
        char:FindFirstChild("LeftLowerLeg"),
        char:FindFirstChild("RightLowerLeg"),
        char:FindFirstChild("LeftFoot"),
        char:FindFirstChild("RightFoot"),
    }
end

local function ClosestBodyPart(char)
    local closestpart = nil
    local shortestdist = math.huge
    
    local bodyparts = GetBodyParts(char)
    local mousepos = UserInputService:GetMouseLocation()
    
    for _, part in pairs(bodyparts) do
        if part then
            local screenpos, onscreen = Camera:WorldToViewportPoint(part.Position)
            
            if onscreen then
                local dist = math.sqrt(
                    (screenpos.X - mousepos.X)^2 +
                    (screenpos.Y - mousepos.Y)^2
                )
                
                if dist < shortestdist then
                    shortestdist = dist
                    closestpart = part
                end
            end
        end
    end
    
    return closestpart
end

-- Advanced Prediction Function
local function PredictedPosition(part, config)
    if not config['use prediction'] then return part.Position end
    
    local vel = part.AssemblyLinearVelocity
    local prediction = config['prediction']
    
    local predX = prediction['x'] or 0.145
    local predY = prediction['y'] or 0.155
    local predZ = prediction['z'] or 0.145
    
    local predictedPos = part.Position + Vector3.new(
        vel.X * predX,
        vel.Y * predY,
        vel.Z * predZ
    )
    
    -- Gravity compensation
    if config['gravity compensation'] then
        local gravity = workspace.Gravity or 196.2
        local timeFactor = (predX + predY + predZ) / 3
        local verticalVel = vel.Y
        
        if math.abs(verticalVel) > 5 then
            local gravityOffset = 0.5 * gravity * (timeFactor * timeFactor)
            predictedPos = predictedPos + Vector3.new(0, gravityOffset * 0.01, 0)
        end
    end
    
    -- Adaptive prediction
    if config['adaptive prediction'] then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local distance = (char.HumanoidRootPart.Position - part.Position).Magnitude
            local distanceFactor = math.clamp(distance / 100, 0.8, 1.5)
            local adjustedVel = vel * distanceFactor
            predictedPos = part.Position + Vector3.new(
                adjustedVel.X * predX,
                adjustedVel.Y * predY,
                adjustedVel.Z * predZ
            )
        end
    end
    
    -- Velocity boost for fast targets
    if config['velocity boost'] then
        local speed = vel.Magnitude
        if speed > 30 then
            local boostFactor = math.clamp(speed / 50, 1.0, 2.0)
            predictedPos = part.Position + (vel * predX * boostFactor)
        end
    end
    
    return predictedPos
end

-- Find closest player to cursor (C++ port)
local function GetClosestPlayerFromCursor()
    local mousepos = UserInputService:GetMouseLocation()
    local closestPlayer = nil
    local shortestDistance = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if PlayerKnocked(player) then
                continue
            end
            
            local char = player.Character
            local upperTorso = char:FindFirstChild("UpperTorso")
            if not upperTorso then continue end
            
            if not WithinDistance(upperTorso, cfg['silent aimbot']['distance']) then
                continue
            end
            
            if not CanSee(upperTorso) then
                continue
            end
            
            local screenpos, onscreen = Camera:WorldToViewportPoint(upperTorso.Position)
            if not onscreen then continue end
            
            local dist = math.sqrt(
                (screenpos.X - mousepos.X)^2 +
                (screenpos.Y - mousepos.Y)^2
            )
            
            if dist < shortestDistance then
                shortestDistance = dist
                closestPlayer = player
            end
        end
    end
    
    return closestPlayer
end

-- Update keybind state (must unselect before selecting new target)
local function UpdateSilentAimKeyState()
    if not cfg['binds']['silent aim'] then return end
    
    local key = Enum.KeyCode[cfg['binds']['silent aim']]
    if not key then return end
    
    local keyPressed = UserInputService:IsKeyDown(key)
    
    if keyPressed and not LastKeyState then
        -- If already locked, unlock first
        if SilentAimLocked then
            SilentAimLocked = false
            CachedTarget = nil
            TargetData.ready = false
        else
            -- Only lock if not currently locked
            SilentAimLocked = true
        end
    end
    
    LastKeyState = keyPressed
end

-- Check if silent aim should be active
local function ShouldSilentAimBeActive()
    if not cfg['silent aimbot']['enabled'] then
        return false
    end
    
    if SelfKnocked() then
        return false
    end
    
    -- Removed knife check from silent aim (only for triggerbot now)
    
    return SilentAimLocked
end

-- Main silent aim thread (finds target)
local function SilentAimThread1()
    while true do
        task.wait(0.002)
        
        UpdateSilentAimKeyState()
        
        if not ShouldSilentAimBeActive() then
            task.wait(0.1)
            TargetData.ready = false
            CachedTarget = nil
            continue
        end
        
        -- Only find new target when first locking (not already cached)
        if not CachedTarget then
            local target = GetClosestPlayerFromCursor()
            if target then
                CachedTarget = target
            else
                TargetData.ready = false
                continue
            end
        end
        
        if CachedTarget then
            -- Auto-unlock if target gets knocked
            if PlayerKnocked(CachedTarget) then
                SilentAimLocked = false
                CachedTarget = nil
                TargetData.ready = false
                continue
            end
            
            local char = CachedTarget.Character
            if not char then
                SilentAimLocked = false
                CachedTarget = nil
                TargetData.ready = false
                continue
            end
            
            local targetPart = nil
            if cfg['silent aimbot']['hitpart'] == 'Closest Part' then
                targetPart = ClosestBodyPart(char)
            else
                targetPart = char:FindFirstChild(cfg['silent aimbot']['hitpart'])
            end
            
            if not targetPart then
                targetPart = char:FindFirstChild("UpperTorso") or char:FindFirstChild("HumanoidRootPart")
            end
            
            if targetPart then
                local predictedPos = PredictedPosition(targetPart, cfg['silent aimbot'])
                local screenpos, onscreen = Camera:WorldToViewportPoint(predictedPos)
                
                if onscreen then
                    TargetData.screenPos = Vector2.new(screenpos.X, screenpos.Y)
                    TargetData.part = targetPart
                    TargetData.player = CachedTarget
                    TargetData.predictedPos = predictedPos
                    TargetData.ready = true
                else
                    TargetData.ready = false
                end
            else
                TargetData.ready = false
            end
        end
    end
end

-- Target Line Update
local function UpdateTargetLine()
    if not cfg['target line']['enabled'] then
        TargetLine.Visible = false
        return
    end
    
    if not SilentAimLocked or not TargetData.ready then
        TargetLine.Visible = false
        return
    end
    
    if TargetData.part then
        local screenpos, onscreen = Camera:WorldToViewportPoint(TargetData.part.Position)
        
        if onscreen and screenpos.Z > 0 then
            local mpos = UserInputService:GetMouseLocation()
            
            TargetLine.From = Vector2.new(mpos.X, mpos.Y)
            TargetLine.To = Vector2.new(screenpos.X, screenpos.Y)
            TargetLine.Color = cfg['target line']['color']
            TargetLine.Visible = true
        else
            TargetLine.Visible = false
        end
    else
        TargetLine.Visible = false
    end
end

-- Triggerbot
local function TriggerBot()
    if not cfg['triggerbot']['enabled'] then return end
    if not TriggerBotEnabled then return end
    if HoldingKnife() then return end
    if tick() - LastTriggerClick < cfg['triggerbot']['delay'] then return end
    
    if TargetData.ready and TargetData.part then
        if not CanSee(TargetData.part) then return end
        if not WithinDistance(TargetData.part, cfg['triggerbot']['distance']) then return end
        
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if not tool then return end
        
        tool:Activate()
        LastTriggerClick = tick()
    end
end

-- ESP System
local function AddESP(player)
    if player == LocalPlayer then return end
    if not cfg['esp']['enabled'] then return end
    
    local esp = {
        player = player,
        nametag = Drawing.new("Text"),
    }
    
    esp.nametag.Size = 14
    esp.nametag.Center = true
    esp.nametag.Outline = true
    esp.nametag.OutlineColor = Color3.fromRGB(0, 0, 0)
    esp.nametag.Color = cfg['esp']['color']
    esp.nametag.Font = Drawing.Fonts.Plex
    esp.nametag.Visible = false
    esp.nametag.ZIndex = 1000
    
    ESPLabels[player.UserId] = esp
end

local function RemoveESP(player)
    local esp = ESPLabels[player.UserId]
    if esp then
        esp.nametag:Remove()
        ESPLabels[player.UserId] = nil
    end
end

local function RefreshESP()
    if not cfg['esp']['enabled'] then
        for userid, esp in pairs(ESPLabels) do
            esp.nametag:Remove()
            ESPLabels[userid] = nil
        end
        return
    end
    
    for userid, esp in pairs(ESPLabels) do
        local player = esp.player
        if not player or not player.Parent then
            esp.nametag.Visible = false
            esp.nametag:Remove()
            ESPLabels[userid] = nil
            continue
        end
        
        if player.Character and player.Character.Parent and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Head") then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then
                esp.nametag.Visible = false
                continue
            end
            
            local head = player.Character.Head
            local hrp = player.Character.HumanoidRootPart
            
            local worldpos = head.Position + Vector3.new(0, 1.5, 0)
            local esppos, onscreen = Camera:WorldToViewportPoint(worldpos)
            
            if onscreen and esppos.Z > 0 then
                esp.nametag.Position = Vector2.new(esppos.X, esppos.Y)
                
                local text = ""
                
                if cfg['esp']['show names'] then
                    text = player.Name
                end
                
                if cfg['esp']['show distance'] then
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local dist = (char.HumanoidRootPart.Position - hrp.Position).Magnitude
                        if text ~= "" then
                            text = text .. " [" .. math.floor(dist) .. "]"
                        else
                            text = "[" .. math.floor(dist) .. "]"
                        end
                    end
                end
                
                if cfg['esp']['show health'] then
                    if text ~= "" then
                        text = text .. " [" .. math.floor(hum.Health) .. "]"
                    else
                        text = "[" .. math.floor(hum.Health) .. "]"
                    end
                end
                
                esp.nametag.Text = text
                
                local isTarget = CachedTarget and CachedTarget == player
                esp.nametag.Color = isTarget and Color3.fromRGB(255, 0, 0) or cfg['esp']['color']
                esp.nametag.Visible = true
            else
                esp.nametag.Visible = false
            end
        else
            esp.nametag.Visible = false
        end
    end
end

-- Silent Aim Hook (Mouse.Hit only - safest method)
local OldIndex
OldIndex = hookmetamethod(game, "__index", function(Self, Key)
    if not checkcaller() and Self == Mouse and Key == "Hit" then
        if ShouldSilentAimBeActive() and TargetData.ready and TargetData.predictedPos then
            return CFrame.new(TargetData.predictedPos)
        end
    end
    
    return OldIndex(Self, Key)
end)

-- Rapid Fire System
local function StartRapidFire()
    if RapidFireActive then return end
    RapidFireActive = true
    
    local isMouseDown = false
    
    -- Mouse button tracking
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isMouseDown = true
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isMouseDown = false
        end
    end)
    
    -- Rapid fire loop
    task.spawn(function()
        while cfg['rapid fire v1']['enabled'] do
            if isMouseDown then
                local char = LocalPlayer.Character
                if char then
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool then
                        tool:Activate()
                    end
                end
            end
            task.wait(0.01) -- 100 shots per second
        end
    end)
end

-- Movement Modifications
local function ApplySpeed()
    if not SpeedEnabled then return end
    if not cfg['movement']['speed']['enabled'] then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    hum.WalkSpeed = cfg['movement']['speed']['value']
end

local function ApplySuperJump()
    if not SuperJumpEnabled then return end
    if not cfg['movement']['super jump']['enabled'] then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    hum.JumpPower = cfg['movement']['super jump']['power']
end

