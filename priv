local SniperDBHook
SniperDBHook = hookfunction(math.random, function(...)
    local args = {...}
    if checkcaller() then
        return SniperDBHook(...)
    end
    
    -- Detect bullet spread calls
    if (#args == 0) or 
       (args[1] == -0.05 and args[2] == 0.05) or 
       (args[1] == -0.1) or 
       (args[1] == -0.05) then
        if cfg['sniper db']['enabled'] then
            return SniperDBHook(...) * (cfg['sniper db']['spread amount'] / 100)
        end
    end
    
    return SniperDBHook(...)
end)

