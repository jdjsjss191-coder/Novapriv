local function isPlayerKnockedOrKO(player)
	if not Checks['Knocked'] then return false end
	if not player.Character then return false end
	local be = player.Character:FindFirstChild("BodyEffects")
	if be then
		local ko = be:FindFirstChild("K.O");     if ko and ko.Value then return true end
		local kn = be:FindFirstChild("Knocked"); if kn and kn.Value then return true end
	end
	return false
end

local function isBlacklisted(player)
	local bl = CFG['Blacklist']
	if not bl or not bl['Enabled'] then return false end
	for _, entry in ipairs(bl['Players'] or {}) do
		if tostring(entry):lower() == tostring(player.Name):lower() then return true end
	end
	return false
end

local KNIFE_C = CFG['Knife Check']
local function isHoldingKnife()
	if not KNIFE_C or not KNIFE_C['Enabled'] then return false end
	local char = LocalPlayer.Character
	if not char then return false end
	local tool = char:FindFirstChildOfClass('Tool')
	if not tool then return false end
	for _, name in ipairs(KNIFE_C['Names'] or {}) do
		if tool.Name == name or tool.Name:lower():find(name:lower(), 1, true) then return true end
	end
	return false
end

local rayParams = RaycastParams.new()
rayParams.FilterType  = Enum.RaycastFilterType.Exclude
rayParams.IgnoreWater = true

local function canSeeTarget(part)
	if not Checks['Visible'] then return true end
	if not part or not part.Parent then return false end
	local char = part.Parent
	rayParams.FilterDescendantsInstances = { LocalPlayer.Character, char }
	local origin = Camera.CFrame.Position
	local result = Workspace:Raycast(origin, part.Position - origin, rayParams)
	return result == nil or result.Instance:IsDescendantOf(char)
end

local function getBodyParts(character)
	return {
		character:FindFirstChild("Head"),
		character:FindFirstChild("UpperTorso"),
		character:FindFirstChild("HumanoidRootPart"),
		character:FindFirstChild("LowerTorso"),
		character:FindFirstChild("LeftUpperArm"),  character:FindFirstChild("RightUpperArm"),
		character:FindFirstChild("LeftLowerArm"),  character:FindFirstChild("RightLowerArm"),
		character:FindFirstChild("LeftHand"),      character:FindFirstChild("RightHand"),
		character:FindFirstChild("LeftUpperLeg"),  character:FindFirstChild("RightUpperLeg"),
		character:FindFirstChild("LeftLowerLeg"),  character:FindFirstChild("RightLowerLeg"),
		character:FindFirstChild("LeftFoot"),      character:FindFirstChild("RightFoot"),
	}
end

local function getClosestBodyPart(character)
	local best, bd = nil, math.huge
	local mp = UserInputService:GetMouseLocation()
	for _, part in pairs(getBodyParts(character)) do
		if part then
			local sp, on = Camera:WorldToViewportPoint(part.Position)
			if on then
				local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
				if d < bd then bd = d; best = part end
			end
		end
	end
	return best
end

local function getPredictedPosition(part)
	local pred = SA['Prediction']
	if not pred then return part.Position end
	local px, py, pz = pred['X'] or 0, pred['Y'] or 0, pred['Z'] or 0
	if px == 0 and py == 0 and pz == 0 then return part.Position end
	local vel   = part.AssemblyLinearVelocity
	local scale = math.clamp((part.Position - Camera.CFrame.Position).Magnitude / 100, 0.05, 1)
	return part.Position + Vector3.new(vel.X*px*scale, vel.Y*py*scale, vel.Z*pz*scale)
end

local BotProxies  = {}
local botRefreshT = 0

local function matchesBotPattern(name)
	if not BOT_C or not BOT_C['Enabled'] then return false end
	return string.find(name:lower(), (BOT_C['Pattern'] or 'bot'):lower(), 1, true) ~= nil
end

local function makeBotProxy(name)
	local proxy = { _isBot=true, _model=nil, Name=name, DisplayName=name, UserId='bot_'..name, Parent=Players }
	setmetatable(proxy, { __index = function(t, k)
		if k == 'Character' then
			local m = t._model
			if not m or not m.Parent then return nil end
			local hum = m:FindFirstChildOfClass('Humanoid')
			if hum and hum.Health <= 0 then return nil end
			return m
		end
	end })
	return proxy
end

local function refreshBotProxies()
	if not BOT_C or not BOT_C['Enabled'] then BotProxies = {}; return end
	local seen = {}
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA('Model') and matchesBotPattern(obj.Name)
			and obj:FindFirstChildOfClass('Humanoid') and obj:FindFirstChild('HumanoidRootPart') then
			seen[obj.Name] = obj
			if not BotProxies[obj.Name] then BotProxies[obj.Name] = makeBotProxy(obj.Name) end
			BotProxies[obj.Name]._model = obj
		end
	end
	for name in pairs(BotProxies) do if not seen[name] then BotProxies[name] = nil end end
end

RunService.Heartbeat:Connect(function()
	if isShutdown then return end
	if tick() - botRefreshT < 2 then return end
	botRefreshT = tick(); refreshBotProxies()
end)

local function getAllTargets()
	local t = {}
	for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then t[#t+1] = p end end
	for _, proxy in pairs(BotProxies) do t[#t+1] = proxy end
	return t
end

local function isBotDead(proxy)
	local char = proxy.Character; if not char then return true end
	local hum = char:FindFirstChildOfClass('Humanoid')
	return hum and hum.Health <= 0
end

local function clIsKnocked(char)
	if not char then return false end
	local be = char:FindFirstChild("BodyEffects")
	if be then local k = be:FindFirstChild("K.O"); if k and k.Value then return true end end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		local s = hum:GetState()
		if s == Enum.HumanoidStateType.Dead or s == Enum.HumanoidStateType.Physics
		or s == Enum.HumanoidStateType.Ragdoll then return true end
	end
	return false
end

local function clFindClosest()
	local mp       = UserInputService:GetMouseLocation()
	local fovCfg   = CL_C['FOV'] or {}
	local fovLimit = (fovCfg['Enabled'] and fovCfg['Size']) or math.huge
	local best, bd = nil, math.huge
	for _, target in ipairs(getAllTargets()) do
		local isBot = type(target) == 'table' and target._isBot
		if not isBot and isBlacklisted(target) then continue end
		local char = target.Character
		if not char or clIsKnocked(char) then continue end
		local hum = char:FindFirstChildOfClass('Humanoid')
		if not hum or hum.Health <= 0 then continue end
		local hrp = char:FindFirstChild('HumanoidRootPart')
		if not hrp then continue end
		local sp, on = Camera:WorldToViewportPoint(hrp.Position)
		if on and sp.Z > 0 then
			local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
			if d <= fovLimit and d < bd then bd = d; best = hrp end
		end
	end
	return best
end

local function findClosestTarget()
	if isHoldingKnife() then return nil end
	local best, bd = nil, math.huge
	local mp       = UserInputService:GetMouseLocation()
	local fovLimit = (SA['FOV']['Enabled'] and SA['FOV']['Size']) or math.huge
	local maxDist  = (SA['Distance Check']['Enabled'] and SA['Distance Check']['Max']) or math.huge
	local camPos   = Camera.CFrame.Position
	for _, target in ipairs(getAllTargets()) do
		local isBot = type(target) == 'table' and target._isBot
		if not isBot and isBlacklisted(target) then continue end
		local char = target.Character
		if not char or not char:FindFirstChild('HumanoidRootPart') then continue end
		if isBot and isBotDead(target) or (not isBot and isPlayerKnockedOrKO(target)) then continue end
		local hrp = char:FindFirstChild('HumanoidRootPart')
		if hrp and (hrp.Position - camPos).Magnitude > maxDist then continue end
		for _, part in pairs(getBodyParts(char)) do
			if part and canSeeTarget(part) then
				local sp, on = Camera:WorldToViewportPoint(part.Position)
				if on then
					local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
					if d < bd and d <= fovLimit then bd = d; best = part end
				end
			end
		end
	end
	return best
end

local grm      = getrawmetatable(game)
local oldIndex = grm.__index
setreadonly(grm, false)

local currentPlaceId = game.PlaceId
local isPrisonWars   = currentPlaceId == 155615604
local isArsenal      = currentPlaceId == 286090429

if isPrisonWars or isArsenal then
	local oldNamecall
	oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(...)
		local method, args = getnamecallmethod(), {...}
		if args[1] == Workspace and not checkcaller() and method == "Raycast" then
			if SA and SA['Enabled'] and currentTarget and currentTarget.Parent then
				if not isHoldingKnife() then
					local origin = args[2]
					local aimPos = getPredictedPosition(currentTarget)
					args[2], args[3] = origin, (aimPos - origin).Unit * 1000
					return oldNamecall(table.unpack(args))
				end
			end
		end
		return oldNamecall(...)
	end))
else
	grm.__index = function(self, key)
		if not checkcaller() and self == Mouse and SA and SA['Enabled'] then
			if key == "Hit" or key == "Target" then
				if isHoldingKnife() or not currentTarget then return oldIndex(self, key) end
				local char = currentTarget.Parent
				if not char then return oldIndex(self, key) end
				local rp = Players:GetPlayerFromCharacter(char)
				if rp and isPlayerKnockedOrKO(rp) then return oldIndex(self, key) end
				if not rp then
					local hum = char:FindFirstChildOfClass('Humanoid')
					if not hum or hum.Health <= 0 then return oldIndex(self, key) end
				end
				if not canSeeTarget(currentTarget) then return oldIndex(self, key) end
				local hp      = SA['Hit Part']
				local aimPart = (hp == 'Closest Part') and currentTarget or (char:FindFirstChild(hp) or currentTarget)
				if key == "Target" then return aimPart end
				return CFrame.new(getPredictedPosition(aimPart))
			end
		end
		return oldIndex(self, key)
	end
end

setreadonly(grm, true)

local espLabels = {}
local espGui    = Instance.new("ScreenGui")
