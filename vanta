local tracerLine = Drawing.new("Line")
tracerLine.Visible = false; tracerLine.Thickness = 1
tracerLine.Transparency = 1; tracerLine.ZIndex = 999

local function updateTracer()
	local TR = ESP_C['Tracer']
	if not TR or not TR['Enabled'] then tracerLine.Visible = false; return end
	local tracerPart = nil
	if camLocked and camTarget and camTarget.Parent then
		local char = camTarget.Parent
		tracerPart = char:FindFirstChild(CL_C['Hit Part'] or 'HumanoidRootPart') or camTarget
	elseif isLocking and currentTarget and currentTarget.Parent then
		tracerPart = currentTarget
	elseif tbActive and tbTarget and tbTarget.Character then
		tracerPart = tbTarget.Character:FindFirstChild('HumanoidRootPart')
	end
	if not tracerPart then tracerLine.Visible = false; return end
	local sp, on = Camera:WorldToViewportPoint(tracerPart.Position)
	if not on or sp.Z <= 0 then tracerLine.Visible = false; return end
	local mp = UserInputService:GetMouseLocation()
	tracerLine.From         = Vector2.new(mp.X, mp.Y)
	tracerLine.To           = Vector2.new(sp.X, sp.Y)
	tracerLine.Thickness    = TR['Thickness']    or 1
	tracerLine.Transparency = TR['Transparency'] or 1
	tracerLine.Color        = TR['Color']        or Color3.fromRGB(205,180,219)
	tracerLine.Visible      = true
end

