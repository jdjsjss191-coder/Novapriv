-- ============================================================================
--  TRIGGER BOT
-- ============================================================================
do
	local TBCircle = Drawing.new("Circle")
	TBCircle.Filled = false; TBCircle.Thickness = 1
	TBCircle.NumSides = 64; TBCircle.Transparency = 1; TBCircle.Visible = false

	-- FOV circle visual
	RunService.RenderStepped:Connect(function()
		if not TB_C or not TB_C['Enabled'] then TBCircle.Visible = false; return end
		local fov = TB_C['FOV'] or {}
		if fov['Enabled'] and fov['Visible'] then
			local mp = UserInputService:GetMouseLocation()
			TBCircle.Position = Vector2.new(mp.X, mp.Y)
			TBCircle.Radius   = (fov['Size'] or 20) * 5
			TBCircle.Color    = fov['Color'] or Color3.new(1, 1, 1)
			TBCircle.Visible  = true
		else
			TBCircle.Visible = false
		end
	end)

	local function tbFindTarget()
		if not TB_C or not TB_C['Enabled'] then return nil end
		local fov    = TB_C['FOV'] or {}
		local mp     = UserInputService:GetMouseLocation()
		local radius = (fov['Size'] or 20) * 5
		local best, bd = nil, math.huge
		for _, p in ipairs(getAllTargets()) do
			local isBot = type(p) == 'table' and p._isBot
			if not isBot and isBlacklisted(p) then continue end
			if not p.Character then continue end
			local hum = p.Character:FindFirstChildOfClass('Humanoid')
			if not hum or hum.Health <= 0 then continue end
			if not isBot and isPlayerKnockedOrKO(p) then continue end
			if isBot and isBotDead(p) then continue end
			local hrp = p.Character:FindFirstChild('HumanoidRootPart')
			if not hrp then continue end
			local sp, on = Camera:WorldToViewportPoint(hrp.Position)
			if not on or sp.Z <= 0 then continue end
			local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
			if fov['Enabled'] and d > radius then continue end
			if d < bd then bd = d; best = p end
		end
		return best
	end

	local function tbMouseOnTarget()
		if not tbTarget then return false end
		local char = tbTarget.Character; if not char then return false end
		local hit = Mouse.Target; if not hit then return false end
		return hit == char or hit:IsDescendantOf(char)
	end

	-- Automatic mode: always track closest in FOV
	-- Target mode: continuously find target while tbActive is true
	RunService.Heartbeat:Connect(function()
		if isShutdown or not TB_C or not TB_C['Enabled'] then return end
		if TB_C['Target Mode'] == 'Automatic' then
			if isHoldingKnife() then
				tbTarget = nil; tbActive = false; return
			end
			local t = tbFindTarget()
			if t then tbTarget = t; tbActive = true
			else tbTarget = nil; tbActive = false end
		elseif tbActive then
			if isHoldingKnife() then tbTarget = nil; return end
			local t = tbFindTarget()
			if t then tbTarget = t
			else tbTarget = nil end
		end
	end)

	-- Fire loop
	RunService.Heartbeat:Connect(function()
		if isShutdown or not TB_C or not TB_C['Enabled'] then return end
		if not tbActive or not tbTarget then return end
		if isHoldingKnife() then return end
		if not LocalPlayer.Character then return end
		if not tbMouseOnTarget() then return end
		local tool = LocalPlayer.Character:FindFirstChildWhichIsA('Tool')
		if not tool then return end
		local function clean(s) return s:lower():gsub('[%[%]%- ]', '') end
		local tn = clean(tool.Name)
		local ok = false
		for _, w in ipairs(TB_C['Weapons'] or {}) do
			if tn:find(clean(w), 1, true) then ok = true; break end
		end
		if not ok then return end
		local cd = TB_C['Cooldown'] or 0.1
		if tick() - tbLastShot >= cd then
			task.spawn(function() task.wait(cd); tool:Activate() end)
			tbLastShot = tick()
		end
	end)

	shared._VyronTBCircle = TBCircle
end

do
	local IR_C  = CFG['Infinite Range']
	local PROPS = {'Range','MaxRange','FireRange','Distance','MaxDistance','BulletRange'}
	if IR_C and IR_C['Enabled'] then
		RunService.RenderStepped:Connect(function()
			if not IR_C['Enabled'] then return end
			local char = LocalPlayer.Character
			local tool = char and char:FindFirstChildOfClass('Tool'); if not tool then return end
			local range = IR_C['Range'] or 900000000
			for _, prop in ipairs(PROPS) do
				local v = tool:FindFirstChild(prop)
				if v and (v:IsA('NumberValue') or v:IsA('IntValue')) then v.Value = range end
				local gc = tool:FindFirstChild('Configuration') or tool:FindFirstChild('GunConfig')
				if gc then local r = gc:FindFirstChild(prop)
					if r and (r:IsA('NumberValue') or r:IsA('IntValue')) then r.Value = range end
				end
			end
		end)
	end
end

do
	local SM_C = CFG['Spread Modifier']
	if SM_C and SM_C['Enabled'] and hookfunction then
		local oldRandom
		oldRandom = hookfunction(math.random, function(...)
			local args = {...}
			if checkcaller() then return oldRandom(...) end
			local isSpread = (#args == 0)
				or (args[1] and args[2] and args[1] < 0 and args[2] > 0 and math.abs(args[1]) <= 0.15)
			if isSpread then
				local cfg = CFG['Spread Modifier']
				if not cfg or not cfg['Enabled'] then return oldRandom(...) end
				if cfg['Specific Weapons']['Enabled'] then
					local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass('Tool')
					if not tool then return oldRandom(...) end
					local found = false
					for _, w in ipairs(cfg['Specific Weapons']['Weapons']) do
						if tool.Name:lower():find(w:gsub('%[',''):gsub('%]',''):lower(), 1, true) then found = true; break end
					end
					if not found then return oldRandom(...) end
				end
				return oldRandom(...) * (cfg['Amount'] or 0)
			end
			return oldRandom(...)
		end)
	end
end

