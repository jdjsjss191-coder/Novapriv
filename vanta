UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	local kc = input.KeyCode

	-- Shutdown (always first, exits early since everything is destroyed)
	if kc == Enum.KeyCode[Binds['Shutdown']:upper()] then
		isShutdown = true
		pcall(function()
			setreadonly(getrawmetatable(game), false)
			getrawmetatable(game).__index = oldIndex
			setreadonly(getrawmetatable(game), true)
		end)
		currentTarget = nil; isLocking = false; saWantsLock = false
		lastVisibleTarget = nil; saLockedPlayer = nil
		camLocked = false; camTarget = nil; speedEnabled = false
		tbActive = false; tbTarget = nil
		pcall(function() local hum = getHumanoid(); if hum then hum.WalkSpeed = 16 end end)
		for _, e in pairs(espLabels) do pcall(function() e.tag:Destroy() end) end
		espLabels = {}
		pcall(function() espGui:Destroy() end)
		pcall(function() if hudGui then hudGui:Destroy() end end)
		pcall(function() SAFovCircle:Remove() end)
		pcall(function() CLFovCircle:Remove() end)
		pcall(function() tracerLine:Remove() end)
		pcall(function() if shared._VyronTBCircle then shared._VyronTBCircle:Remove() end end)
		shared.VyronCleanup = nil
		print("[Vyron] Shutdown complete.")
		return
	end

	-- ESP toggle
	if kc == Enum.KeyCode[Binds['ESP']:upper()] then
		ESP_C['Enabled'] = not ESP_C['Enabled']
		if not ESP_C['Enabled'] then for _, e in pairs(espLabels) do e.tag.Visible = false end end
	end

	-- Speed toggle
	if kc == Enum.KeyCode[Binds['Speed']:upper()] then
		speedEnabled = not speedEnabled
		if not speedEnabled then local hum = getHumanoid(); if hum then hum.WalkSpeed = 16 end end
	end

	-- Auto Shoot toggle
	if SA['Enabled'] and Binds['Auto Shoot'] and kc == Enum.KeyCode[Binds['Auto Shoot']:upper()] then
		local AS = SA['Auto Shoot']; if AS then AS['Enabled'] = not AS['Enabled'] end
	end

	-- Camera Lock toggle (Target mode only)
	if CL_C['Enabled'] and CL_C['Target Mode'] ~= 'Automatic'
		and kc == Enum.KeyCode[Binds['Camera Lock']:upper()] then
		if camLocked then
			camLocked = false; camTarget = nil
		else
			if not isHoldingKnife() then
				local best = clFindClosest()
				if best then camLocked = true; camTarget = best end
			end
		end
	end

	-- Trigger Bot toggle (Target mode only)
	if TB_C and TB_C['Enabled'] and TB_C['Target Mode'] ~= 'Automatic'
		and Binds['Trigger Bot'] and kc == Enum.KeyCode[Binds['Trigger Bot']:upper()] then
		if tbActive then
			tbActive = false; tbTarget = nil
		else
			if not isHoldingKnife() then
				tbActive = true
				-- target acquisition happens continuously in Heartbeat
			end
		end
	end

	-- Silent Aim toggle (Target mode only)
	if SA['Enabled'] and SA['Target Mode'] ~= 'Automatic'
		and kc == Enum.KeyCode[Binds['Silent Aim']:upper()] then
		if saWantsLock then
			saWantsLock = false; isLocking = false
			currentTarget = nil; lastVisibleTarget = nil; saLockedPlayer = nil
		else
			if not isHoldingKnife() then
				saWantsLock = true
				-- target acquisition now happens continuously in RenderStepped
			end
		end
	end
end)

