			else lblRF.Visible = false end

			if CFG['Spread Modifier']['Enabled'] then
				lblSM.Visible = true; lblSM.Text = fmt("Spread Mod", nil)
			else lblSM.Visible = false end

			if CFG['Infinite Range']['Enabled'] then
