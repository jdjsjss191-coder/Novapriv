local function makeTag()
	local NT  = ESP_C['Nametag'] or {}
	local lbl = Instance.new("TextLabel", espGui)
	lbl.BackgroundTransparency = 1
	lbl.Size = UDim2.new(0, 200, 0, 20); lbl.AnchorPoint = Vector2.new(0.5, 0.5)
	lbl.TextColor3 = NT['Color'] or Color3.fromRGB(220,220,220)
	lbl.TextSize = NT['Size'] or 8; lbl.TextScaled = false
	lbl.Font = Enum.Font.Legacy
	lbl.TextStrokeTransparency = 0.5; lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0)
	lbl.Text = ""; lbl.Visible = false; lbl.ZIndex = 10
	return lbl
end

local function addESP(player)
	if player == LocalPlayer then return end
	local key = tostring(player.UserId)
	if espLabels[key] then pcall(function() espLabels[key].tag:Destroy() end) end
	espLabels[key] = { player = player, tag = makeTag() }
end

local function removeESP(player)
	local key = tostring(player.UserId)
	local e = espLabels[key]
	if e then pcall(function() e.tag:Destroy() end); espLabels[key] = nil end
end

local function refreshESP()
	if isShutdown or not ESP_C['Enabled'] then
		for _, e in pairs(espLabels) do e.tag.Visible = false end; return
	end
	for _, proxy in pairs(BotProxies) do
		local key = tostring(proxy.UserId)
		if not espLabels[key] then espLabels[key] = { player = proxy, tag = makeTag() } end
	end
	for userId, e in pairs(espLabels) do
		local player = e.player
		local isBot  = type(player) == 'table' and player._isBot
		if isBot then
			if not BotProxies[player.Name] then pcall(function() e.tag:Destroy() end); espLabels[userId] = nil; continue end
		else
			if not player or not player.Parent then pcall(function() e.tag:Destroy() end); espLabels[userId] = nil; continue end
			if isBlacklisted(player) then e.tag.Visible = false; continue end
		end
		local char = player.Character
		if not char then e.tag.Visible = false; continue end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then e.tag.Visible = false; continue end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then e.tag.Visible = false; continue end
		local sp, on = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 2.3, 0))
		if not on or sp.Z <= 0 then e.tag.Visible = false; continue end
		local NT = ESP_C['Nametag'] or {}
		if not NT['Enabled'] then e.tag.Visible = false; continue end
		local isTarget = (currentTarget ~= nil and currentTarget.Parent == char)
		              or (camLocked and camTarget ~= nil and camTarget.Parent == char)
		              or (tbActive and tbTarget ~= nil and tbTarget.Character == char)
		local nameMode = NT['Mode'] or 'Username'
		e.tag.Text       = isBot and player.Name or (nameMode == 'DisplayName' and player.DisplayName) or player.Name
		e.tag.TextColor3 = isTarget
			and (NT['Target Color'] or ESP_C['Target Color'] or Color3.fromRGB(100,255,100))
			or  (NT['Color']        or ESP_C['Color']        or Color3.fromRGB(220,220,220))
		e.tag.TextSize = NT['Size'] or 8
		e.tag.Position = UDim2.new(0, sp.X, 0, sp.Y + 2)
		e.tag.Visible  = true
	end
end

for _, p in pairs(Players:GetPlayers()) do
	if p ~= LocalPlayer then
		addESP(p)
		p.CharacterAdded:Connect(function() removeESP(p); task.wait(0.15); if p.Parent then addESP(p) end end)
		p.CharacterRemoving:Connect(function() removeESP(p) end)
	end
end
Players.PlayerAdded:Connect(function(p)
	task.wait(0.1); addESP(p)
	p.CharacterAdded:Connect(function() removeESP(p); task.wait(0.15); if p.Parent then addESP(p) end end)
	p.CharacterRemoving:Connect(function() removeESP(p) end)
end)
