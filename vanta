local autoShootLastFire = 0
RunService.Heartbeat:Connect(function()
	if isShutdown then return end
	local AS = SA and SA['Auto Shoot']
	if not (AS and AS['Enabled'] and SA['Enabled'] and isLocking and currentTarget and currentTarget.Parent) then return end
	if isHoldingKnife() then return end
	local now = tick(); local delay = AS['Delay'] or 0.1
	if now - autoShootLastFire < delay then return end
	if AS['FOV Check'] and SA['FOV']['Enabled'] then
		local mp = UserInputService:GetMouseLocation()
		local sp, on = Camera:WorldToViewportPoint(currentTarget.Position)
		if not on or sp.Z <= 0 or (Vector2.new(sp.X,sp.Y)-mp).Magnitude > (SA['FOV']['Size'] or 160) then return end
	end
	if AS['Mode'] ~= 'Part' and not canSeeTarget(currentTarget) then return end
	local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass('Tool')
	if tool then pcall(function() tool:Activate(); autoShootLastFire = now end) end
end)

RunService.RenderStepped:Connect(function()
	if isShutdown then return end

	-- Silent Aim: Automatic mode
	if SA['Enabled'] and SA['Target Mode'] == 'Automatic' then
		if isHoldingKnife() then
			currentTarget = nil; isLocking = false; lastVisibleTarget = nil
		else
			local fovLimit = (SA['FOV']['Enabled'] and SA['FOV']['Size']) or math.huge
			local maxDist  = (SA['Distance Check']['Enabled'] and SA['Distance Check']['Max']) or math.huge
			local camPos   = Camera.CFrame.Position
			local mp       = UserInputService:GetMouseLocation()
			local best, bd = nil, math.huge
			for _, target in ipairs(getAllTargets()) do
				local isBot = type(target) == 'table' and target._isBot
				if not isBot and isBlacklisted(target) then continue end
				local char = target.Character
				if not char or not char:FindFirstChild('HumanoidRootPart') then continue end
				if isBot and isBotDead(target) or (not isBot and isPlayerKnockedOrKO(target)) then continue end
				local hrp = char:FindFirstChild('HumanoidRootPart')
				if hrp and (hrp.Position - camPos).Magnitude > maxDist then continue end
				local sp, on = Camera:WorldToViewportPoint(hrp.Position)
				if on and sp.Z > 0 then
					local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
					if d <= fovLimit and d < bd then bd = d; best = hrp end
				end
			end
			if best then
				local char = best.Parent; local hp = SA['Hit Part']
				local part = (hp == 'Closest Part') and getClosestBodyPart(char) or char:FindFirstChild(hp) or best
				currentTarget = part; isLocking = true; lastVisibleTarget = part
			else
				currentTarget = nil; isLocking = false; lastVisibleTarget = nil
			end
		end
	end

	-- Silent Aim: Target mode acquisition (continuously find target while saWantsLock is true)
	if SA['Enabled'] and SA['Target Mode'] ~= 'Automatic' and saWantsLock and not isLocking then
		if not isHoldingKnife() then
			local target = findClosestTarget()
			if target then
				currentTarget = target; lastVisibleTarget = target; isLocking = true
				local rp = Players:GetPlayerFromCharacter(target.Parent)
				if rp then saLockedPlayer = rp
				else for _, proxy in pairs(BotProxies) do
					if proxy.Character == target.Parent then saLockedPlayer = proxy; break end
				end end
			end
		end
	end

	-- Silent Aim: Target mode tracking
	if SA['Target Mode'] ~= 'Automatic' and isLocking and currentTarget then
		local char = currentTarget.Parent
		local rp   = char and Players:GetPlayerFromCharacter(char)
		local hum  = char and char:FindFirstChildOfClass('Humanoid')
		if not char or (hum and hum.Health <= 0) or (rp and isPlayerKnockedOrKO(rp)) then
			if Checks['Respawn Check'] == false and saLockedPlayer then
				currentTarget = nil; isLocking = false; lastVisibleTarget = nil
				local lockedP = saLockedPlayer; local isBot = type(lockedP) == 'table' and lockedP._isBot
				task.spawn(function()
					local newChar
					if isBot then
						repeat task.wait(0.2) until (not saWantsLock or saLockedPlayer ~= lockedP)
							or (BotProxies[lockedP.Name] and BotProxies[lockedP.Name].Character)
						newChar = BotProxies[lockedP.Name] and BotProxies[lockedP.Name].Character
					else
						newChar = lockedP.CharacterAdded:Wait()
						newChar:WaitForChild('HumanoidRootPart', 10); task.wait(0.1)
					end
					if saWantsLock and saLockedPlayer == lockedP and newChar then
						local hp = SA['Hit Part']
						local part = (hp == 'Closest Part') and getClosestBodyPart(newChar)
						          or newChar:FindFirstChild(hp) or newChar:FindFirstChild('HumanoidRootPart')
						if part then currentTarget = part; lastVisibleTarget = part; isLocking = true end
					end
				end)
			else
				currentTarget = nil; isLocking = false; saWantsLock = false
				lastVisibleTarget = nil; saLockedPlayer = nil
			end
		else
			if canSeeTarget(currentTarget) then lastVisibleTarget = currentTarget end
			if SA['Hit Part'] == 'Closest Part' then
				local p = getClosestBodyPart(char); if p then currentTarget = p end
			end
		end
	end

	-- Camera Lock: Automatic targeting
	if CL_C['Enabled'] and CL_C['Target Mode'] == 'Automatic' then
		if isHoldingKnife() then
			camLocked = false; camTarget = nil
		else
			local best = clFindClosest()
			if best then camLocked = true; camTarget = best
			else camLocked = false; camTarget = nil end
		end
	end

	-- Camera Lock: FOV circle
	if CL_C['Enabled'] then
		local fovCfg = CL_C['FOV'] or {}
		if fovCfg['Enabled'] and fovCfg['Visible'] then
			local mp = UserInputService:GetMouseLocation()
			CLFovCircle.Position = Vector2.new(mp.X, mp.Y)
			CLFovCircle.Radius   = fovCfg['Size'] or 120
			CLFovCircle.Color    = fovCfg['Color'] or Color3.fromRGB(255,255,255)
			CLFovCircle.Visible  = true
		else
			CLFovCircle.Visible = false
		end
	else
		CLFovCircle.Visible = false
	end

	-- Camera Lock: aim
	if CL_C['Enabled'] and camLocked and camTarget and not isHoldingKnife() then
		local char = camTarget.Parent
		if not char or clIsKnocked(char) then
			camLocked = false; camTarget = nil
		else
			local hitPart = CL_C['Hit Part'] or 'HumanoidRootPart'
			local aimPart = (hitPart == 'Closest Part') and getClosestBodyPart(char)
			              or char:FindFirstChild(hitPart) or camTarget
			local pred    = CL_C['Prediction'] or {}
			local vel     = Vector3.new(0,0,0)
			pcall(function() vel = camTarget.AssemblyLinearVelocity end)
			local scale   = math.clamp((aimPart.Position - Camera.CFrame.Position).Magnitude / 100, 0.05, 1)
			local px, py, pz = pred['X'] or 0, pred['Y'] or 0, pred['Z'] or 0
			local aimPos  = aimPart.Position + Vector3.new(vel.X*px*scale, vel.Y*py*scale, vel.Z*pz*scale)
			local targetCF = CFrame.new(Camera.CFrame.Position, aimPos)
			local smooth   = math.clamp(tonumber(CL_C['Smoothness']) or 0, 0, 0.99)
			Camera.CFrame  = smooth <= 0 and targetCF or Camera.CFrame:Lerp(targetCF, 1 - smooth)
		end
	end

	updateFOV()
	updateTracer()
	refreshESP()
end)

