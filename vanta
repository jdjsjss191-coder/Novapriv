local SAFovCircle = Drawing.new("Circle")
SAFovCircle.Filled = false; SAFovCircle.Thickness = 1
SAFovCircle.NumSides = 128; SAFovCircle.Transparency = 1; SAFovCircle.Visible = false

local function updateFOV()
	local saFov = SA['FOV']
	if not SA['Enabled'] or not saFov['Enabled'] or not saFov['Visible'] then
		SAFovCircle.Visible = false; return
	end
	local mp = UserInputService:GetMouseLocation()
	SAFovCircle.Position = Vector2.new(mp.X, mp.Y)
	SAFovCircle.Radius   = saFov['Size']
	SAFovCircle.Color    = isLocking and (saFov['Active Color'] or Color3.fromRGB(100,230,130))
	                                  or (saFov['Color']        or Color3.fromRGB(255,255,255))
	SAFovCircle.Visible  = true
end

local CLFovCircle = Drawing.new("Circle")
CLFovCircle.Filled = false; CLFovCircle.Thickness = 1
