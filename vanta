UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end

	-- Shutdown
	if input.KeyCode == Enum.KeyCode[Binds['Shutdown']:upper()] then
		isShutdown = true
		-- restore metatable
		pcall(function()
			setreadonly(getrawmetatable(game), false)
			getrawmetatable(game).__index = oldIndex
			setreadonly(getrawmetatable(game), true)
		end)
		-- clear state
		currentTarget = nil; isLocking = false; saWantsLock = false
		lastVisibleTarget = nil; saLockedPlayer = nil; speedEnabled = false
		-- restore walkspeed
		pcall(function()
			local hum = getHumanoid()
			if hum then hum.WalkSpeed = 16 end
		end)
		-- destroy ESP
		for _, e in pairs(espLabels) do pcall(function() e.tag:Destroy() end) end
		espLabels = {}
		pcall(function() espGui:Destroy() end)
		pcall(function() SAFovCircle:Remove() end)
		shared.VyronCleanup = nil
		print("[Vyron] Shutdown complete.")
		return
	end

	-- ESP toggle
	if input.KeyCode == Enum.KeyCode[Binds['ESP']:upper()] then
		ESP_C['Enabled'] = not ESP_C['Enabled']
		if not ESP_C['Enabled'] then
			for _, e in pairs(espLabels) do e.tag.Visible = false end
		end
		return
	end

	-- Speed toggle
	if SPD_C['Enabled'] and input.KeyCode == Enum.KeyCode[Binds['Speed']:upper()] then
		speedEnabled = not speedEnabled
		if not speedEnabled then
			local hum = getHumanoid()
			if hum then hum.WalkSpeed = 16 end
		end
		return
	end

	-- Auto Shoot toggle
	if SA['Enabled'] and Binds['Auto Shoot'] and input.KeyCode == Enum.KeyCode[Binds['Auto Shoot']:upper()] then
		local AS = SA['Auto Shoot']
		if AS then AS['Enabled'] = not AS['Enabled'] end
		return
	end

	-- Silent Aim toggle (Target mode only)
	if input.KeyCode ~= Enum.KeyCode[Binds['Silent Aim']:upper()] then return end
	if not SA['Enabled'] or SA['Target Mode'] == 'Automatic' then return end

	if saWantsLock then
		saWantsLock = false; isLocking = false
		currentTarget = nil; lastVisibleTarget = nil; saLockedPlayer = nil
	else
		if isHoldingKnife() then return end
		saWantsLock = true
		local target = findClosestTarget()
		if target then
			currentTarget = target; lastVisibleTarget = target; isLocking = true
			local realPlayer = Players:GetPlayerFromCharacter(target.Parent)
			if realPlayer then
				saLockedPlayer = realPlayer
			else
				for _, proxy in pairs(BotProxies) do
					if proxy.Character == target.Parent then saLockedPlayer = proxy; break end
				end
			end
		end
	end
end)

LocalPlayer.CharacterAdded:Connect(function()
	currentTarget = nil; isLocking = false; saWantsLock = false
	lastVisibleTarget = nil; saLockedPlayer = nil; speedEnabled = false
end)

-- Register cleanup for re-execution
shared.VyronCleanup = function()
	isShutdown = true
	pcall(function()
		setreadonly(getrawmetatable(game), false)
		getrawmetatable(game).__index = oldIndex
		setreadonly(getrawmetatable(game), true)
	end)
	for _, e in pairs(espLabels) do pcall(function() e.tag:Destroy() end) end
	espLabels = {}
	pcall(function() espGui:Destroy() end)
	pcall(function() SAFovCircle:Remove() end)
end

print("[Vyron] Ready.")

