-- ============================================================================
--  AUTO SHOOT
-- ============================================================================
local autoShootLastFire = 0

RunService.Heartbeat:Connect(function()
	if isShutdown then return end
	local AS = SA and SA['Auto Shoot']
	if not (AS and AS['Enabled'] and SA['Enabled'] and isLocking and currentTarget and currentTarget.Parent) then return end
	if isHoldingKnife() then return end
	local now   = tick()
	local delay = AS['Delay'] or 0.1
	if now - autoShootLastFire < delay then return end

	local withinFOV = true
	if AS['FOV Check'] and SA['FOV'] and SA['FOV']['Enabled'] then
		local mp = UserInputService:GetMouseLocation()
		local sp, on = Camera:WorldToViewportPoint(currentTarget.Position)
		if on and sp.Z > 0 then
			withinFOV = (Vector2.new(sp.X, sp.Y) - mp).Magnitude <= (SA['FOV']['Size'] or 160)
		else
			withinFOV = false
		end
	end
	if not withinFOV then return end

	local canShoot = AS['Mode'] == 'Part' or canSeeTarget(currentTarget)
	if not canShoot then return end

	local char = LocalPlayer.Character
	local tool = char and char:FindFirstChildOfClass('Tool')
	if tool then
		pcall(function() tool:Activate(); autoShootLastFire = now end)
	end
end)

-- ============================================================================
--  RENDER LOOP
-- ============================================================================
RunService.RenderStepped:Connect(function()
	if isShutdown then return end

	-- AUTOMATIC mode: always lock closest target in FOV
	if SA['Enabled'] and SA['Target Mode'] == 'Automatic' then
		if isHoldingKnife() then
			currentTarget = nil; isLocking = false; lastVisibleTarget = nil
		else
			local saFov    = SA['FOV']
			local fovLimit = (saFov['Enabled'] and saFov['Size']) or math.huge
			local distCfg  = SA['Distance Check']
			local maxDist  = (distCfg and distCfg['Enabled'] and distCfg['Max']) or math.huge
			local camPos   = Camera.CFrame.Position
			local mp       = UserInputService:GetMouseLocation()
			local best, bd = nil, math.huge

			for _, target in ipairs(getAllTargets()) do
				local isBot = type(target) == 'table' and target._isBot
				if not isBot and isBlacklisted(target) then continue end
				local char = target.Character
				if not char or not char:FindFirstChild('HumanoidRootPart') then continue end
				local skip = isBot and isBotDead(target) or (not isBot and isPlayerKnockedOrKO(target))
				if skip then continue end
				local hrp = char:FindFirstChild('HumanoidRootPart')
				if hrp and (hrp.Position - camPos).Magnitude > maxDist then continue end
				local sp, on = Camera:WorldToViewportPoint(hrp.Position)
				if on and sp.Z > 0 then
					local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
					if d <= fovLimit and d < bd then bd = d; best = hrp end
				end
			end

			if best then
				local char = best.Parent
				local hp   = SA['Hit Part']
				local part = (hp == 'Closest Part') and getClosestBodyPart(char)
				          or char:FindFirstChild(hp) or best
				currentTarget = part; isLocking = true; lastVisibleTarget = part
			else
				currentTarget = nil; isLocking = false; lastVisibleTarget = nil
			end
		end
	end

	-- TARGET mode: keep tracking locked target
	if SA['Target Mode'] ~= 'Automatic' and isLocking and currentTarget then
		local char       = currentTarget.Parent
		local realPlayer = char and Players:GetPlayerFromCharacter(char)
		local hum        = char and char:FindFirstChildOfClass('Humanoid')
		local dead       = not char or (hum and hum.Health <= 0)
		local knocked    = realPlayer and isPlayerKnockedOrKO(realPlayer)
		if dead or knocked then
			if Checks['Respawn Check'] == false and saLockedPlayer then
				currentTarget = nil; isLocking = false; lastVisibleTarget = nil
				local lockedP = saLockedPlayer
				local isBot   = type(lockedP) == 'table' and lockedP._isBot
				task.spawn(function()
					local newChar
					if isBot then
						repeat task.wait(0.2) until
							(not saWantsLock or saLockedPlayer ~= lockedP) or
							(BotProxies[lockedP.Name] and BotProxies[lockedP.Name].Character)
						newChar = BotProxies[lockedP.Name] and BotProxies[lockedP.Name].Character
					else
						newChar = lockedP.CharacterAdded:Wait()
						newChar:WaitForChild('HumanoidRootPart', 10); task.wait(0.1)
					end
					if saWantsLock and saLockedPlayer == lockedP and newChar then
						local hp   = SA['Hit Part']
						local part = (hp == 'Closest Part') and getClosestBodyPart(newChar)
						          or newChar:FindFirstChild(hp)
						          or newChar:FindFirstChild('HumanoidRootPart')
						if part then currentTarget = part; lastVisibleTarget = part; isLocking = true end
					end
				end)
			else
				currentTarget = nil; isLocking = false; saWantsLock = false
				lastVisibleTarget = nil; saLockedPlayer = nil
			end
		else
			if canSeeTarget(currentTarget) then lastVisibleTarget = currentTarget end
			local hp = SA['Hit Part']
			if hp == 'Closest Part' then
				local newPart = getClosestBodyPart(char)
				if newPart then currentTarget = newPart end
			end
		end
	end

	updateFOV()
	refreshESP()
end)

-- ============================================================================
--  SPREAD MODIFIER
-- ============================================================================
do
	local SM_C = CFG['Spread Modifier']
	if SM_C and SM_C['Enabled'] and hookfunction then
		local oldRandom
		oldRandom = hookfunction(math.random, function(...)
			local args = {...}
			if checkcaller() then return oldRandom(...) end
			local isSpread = (#args == 0)
				or (args[1] and args[2] and args[1] < 0 and args[2] > 0 and math.abs(args[1]) <= 0.15)
			if isSpread then
				local cfg = CFG['Spread Modifier']
				if not cfg or not cfg['Enabled'] then return oldRandom(...) end
				if cfg['Specific Weapons']['Enabled'] then
					local char = LocalPlayer.Character
					local tool = char and char:FindFirstChildOfClass('Tool')
					if not tool then return oldRandom(...) end
					local found = false
					for _, w in ipairs(cfg['Specific Weapons']['Weapons']) do
						local clean = w:gsub('%[',''):gsub('%]',''):lower()
						if tool.Name:lower():find(clean, 1, true) then found = true; break end
					end
					if not found then return oldRandom(...) end
				end
				return oldRandom(...) * (cfg['Amount'] or 0)
			end
			return oldRandom(...)
		end)
	end
end

